@dlt.table(
    name="executive_dashboard_kpis",
    comment="Executive dashboard with key performance indicators and strategic metrics",
    table_properties={
        "quality": "gold",
        "delta.autoOptimize.optimizeWrite": "true",
        "delta.autoOptimize.autoCompact": "true"
    }
)
def executive_dashboard_kpis():
    """
    Executive dashboard with comprehensive KPIs for strategic decision making
    """
    transactions = dlt.readStream(f"{catalog}.{silver_schema}.fact_transactions_enriched")
    customers = dlt.readStream(f"{catalog}.{silver_schema}.dim_customers_enhanced")
    accounts = dlt.readStream(f"{catalog}.{silver_schema}.dim_accounts")
    
    # Calculate comprehensive business metrics
    current_month = current_date().cast("date")
    previous_month = add_months(current_month, -1)
    current_year = year(current_date())
    
    # Customer metrics
    customer_metrics = (
        customers
        .agg(
            count("customer_id").alias("total_customers"),
            countDistinct("customer_id").alias("unique_customers"),
            avg("estimated_clv_score").alias("avg_customer_lifetime_value"),
            sum(when(col("risk_category") == "HIGH", 1).otherwise(0)).alias("high_risk_customers"),
            sum(when(col("wealth_segment") == "Affluent", 1).otherwise(0)).alias("affluent_customers"),
            avg("financial_stability_score").alias("avg_financial_stability"),
            countDistinct("customer_segment").alias("unique_segments")
        )
        .withColumn("metric_category", lit("CUSTOMERS"))
        .withColumn("measurement_date", current_date())
    )
    
    # Transaction metrics
    transaction_metrics = (
        transactions
        .filter(col("transaction_year") == current_year)
        .agg(
            count("transaction_id").alias("total_transactions"),
            sum("amount").alias("total_transaction_volume"),
            avg("amount").alias("avg_transaction_amount"),
            countDistinct("customer_id").alias("active_customers"),
            sum(when(col("fraud_risk_level") == "CRITICAL", 1).otherwise(0)).alias("critical_fraud_alerts"),
            sum(when(col("fraud_risk_level").isin(["HIGH", "CRITICAL"]), 1).otherwise(0)).alias("high_fraud_risk_transactions"),
            approx_count_distinct("merchant_id").alias("unique_merchants")
        )
        .withColumn("metric_category", lit("TRANSACTIONS"))
        .withColumn("measurement_date", current_date())
    )
    
    # Account metrics  
    account_metrics = (
        accounts
        .filter(col("__END_AT").isNull())
        .agg(
            count("account_id").alias("total_accounts"),
            countDistinct("customer_id").alias("customers_with_accounts"),
            countDistinct("typ_uctu").alias("account_types"),
            sum(when(col("stav") == "aktivni", 1).otherwise(0)).alias("active_accounts")
        )
        .withColumn("metric_category", lit("ACCOUNTS"))
        .withColumn("measurement_date", current_date())
    )
    
    # Union all metrics (simplified structure for streaming)
    return (
        customer_metrics
        .select(
            lit("EXECUTIVE_KPI").alias("dashboard_type"),
            col("metric_category"),
            col("measurement_date"),
            col("total_customers").cast("double").alias("metric_1"),
            col("avg_customer_lifetime_value").alias("metric_2"),
            col("high_risk_customers").cast("double").alias("metric_3"),
            col("affluent_customers").cast("double").alias("metric_4"),
            current_timestamp().alias("last_updated")
        )
        .unionByName(
            transaction_metrics.select(
                lit("EXECUTIVE_KPI").alias("dashboard_type"),
                col("metric_category"),
                col("measurement_date"),
                col("total_transactions").cast("double").alias("metric_1"),
                col("total_transaction_volume").alias("metric_2"),
                col("critical_fraud_alerts").cast("double").alias("metric_3"),
                col("high_fraud_risk_transactions").cast("double").alias("metric_4"),
                current_timestamp().alias("last_updated")
            ),
            allowMissingColumns=True
        )
    )

@dlt.table(
    name="fraud_detection_dashboard",
    comment="Real-time fraud detection dashboard with alerts and risk analytics",
    table_properties={
        "quality": "gold",
        "delta.autoOptimize.optimizeWrite": "true",
        "delta.enableChangeDataFeed": "true"
    }
)
def fraud_detection_dashboard():
    """
    Real-time fraud detection dashboard for security operations
    """
    transactions = dlt.readStream(f"{catalog}.{silver_schema}.fact_transactions_enriched")
    customers = dlt.readStream(f"{catalog}.{silver_schema}.dim_customers_enhanced")
    
    # Focus on high-risk transactions from the last 24 hours
    high_risk_transactions = (
        transactions
        .filter(col("fraud_risk_level").isin(["HIGH", "CRITICAL"]))
        .filter(col("transaction_date") >= date_sub(current_date(), 1))
        .join(customers, "customer_id", "inner")
    )
    
    return (
        high_risk_transactions
        .select(
            col("transaction_id"),
            col("customer_id"),
            concat_ws(" ", col("jmeno"), col("prijmeni")).alias("customer_name"),
            col("amount"),
            col("transaction_date"),
            col("transaction_type"),
            col("fraud_risk_score"),
            col("fraud_risk_level"),
            col("transaction_risk_category"),
            col("customer_segment"),
            col("risk_category").alias("customer_risk_category"),
            # Alert details
            when(col("is_amount_anomaly"), "AMOUNT_ANOMALY").otherwise("").alias("alert_type_1"),
            when(col("is_unusual_hour"), "UNUSUAL_TIME").otherwise("").alias("alert_type_2"),
            when(col("is_high_velocity"), "HIGH_VELOCITY").otherwise("").alias("alert_type_3"),
            # Recommendations
            when(col("fraud_risk_level") == "CRITICAL", "BLOCK_IMMEDIATELY")
            .when(col("fraud_risk_level") == "HIGH", "MANUAL_REVIEW")
            .otherwise("MONITOR").alias("recommended_action"),
            # Priority scoring
            when(col("fraud_risk_level") == "CRITICAL", 1)
            .when(col("fraud_risk_level") == "HIGH", 2)
            .otherwise(3).alias("priority_order"),
            current_timestamp().alias("alert_generated_at")
        )
        .orderBy("priority_order", col("fraud_risk_score").desc())
    )

@dlt.table(
    name="customer_360_analytics",
    comment="Comprehensive 360-degree customer analytics for relationship management",
    table_properties={
        "quality": "gold",
        "delta.autoOptimize.optimizeWrite": "true",
        "delta.autoOptimize.autoCompact": "true"
    }
)
def customer_360_analytics():
    """
    360-degree customer view with comprehensive analytics and insights
    """
    customers = dlt.readStream(f"{catalog}.{silver_schema}.dim_customers_enhanced")
    transactions = dlt.readStream(f"{catalog}.{silver_schema}.fact_transactions_enriched")
    accounts = dlt.readStream(f"{catalog}.{silver_schema}.dim_accounts")
    account_balances = dlt.readStream(f"{catalog}.{silver_schema}.account_balances_silver")
    
    # Customer transaction summary (last 12 months)
    customer_tx_summary = (
        transactions
        .filter(col("transaction_date") >= add_months(current_date(), -12))
        .groupBy("customer_id")
        .agg(
            count("transaction_id").alias("tx_count_12m"),
            sum("amount").alias("tx_volume_12m"),
            avg("amount").alias("avg_tx_amount_12m"),
            max("amount").alias("max_tx_amount_12m"),
            countDistinct("merchant_id").alias("unique_merchants_12m"),
            sum(when(col("fraud_risk_level").isin(["HIGH", "CRITICAL"]), 1).otherwise(0)).alias("fraud_alerts_12m"),
            max("transaction_date").alias("last_transaction_date")
        )
    )
    
    # Customer account summary
    customer_account_summary = (
        accounts
        .filter(col("__END_AT").isNull())
        .groupBy("customer_id")
        .agg(
            count("account_id").alias("total_accounts"),
            countDistinct("typ_uctu").alias("account_types_count"),
            collect_set("typ_uctu").alias("account_types_list"),
            sum(when(col("stav") == "aktivni", 1).otherwise(0)).alias("active_accounts")
        )
    )
    
    # Latest account balances
    latest_balances = (
        account_balances
        .join(accounts.filter(col("__END_AT").isNull()), "account_id", "inner")
        .groupBy("customer_id")
        .agg(
            sum("balance").alias("total_balance"),
            avg("balance").alias("avg_balance"),
            max("balance").alias("max_balance"),
            count("account_id").alias("accounts_with_balance")
        )
    )
    
    # Comprehensive customer 360 view
    return (
        customers
        .join(customer_tx_summary, "customer_id", "left")
        .join(customer_account_summary, "customer_id", "left")
        .join(latest_balances, "customer_id", "left")
        .select(
            # Customer identity
            col("customer_id"),
            concat_ws(" ", col("jmeno"), col("prijmeni")).alias("full_name"),
            col("email"),
            col("client_age"),
            col("pohlavi").alias("gender"),
            col("mesto").alias("city"),
            
            # Customer segmentation and scoring
            col("customer_segment"),
            col("life_stage"),
            col("wealth_segment"),
            col("banking_tenure_segment"),
            col("risk_category"),
            col("financial_stability_score"),
            col("estimated_clv_score"),
            
            # Financial profile
            col("prijem").alias("annual_income"),
            col("savings_rate"),
            col("savings_category"),
            col("pocet_nemovitosti").alias("property_count"),
            col("housing_status"),
            
            # Account information
            coalesce(col("total_accounts"), lit(0)).alias("total_accounts"),
            coalesce(col("account_types_count"), lit(0)).alias("account_types_count"),
            col("account_types_list"),
            coalesce(col("active_accounts"), lit(0)).alias("active_accounts"),
            
            # Balance information
            coalesce(col("total_balance"), lit(0)).alias("total_balance"),
            coalesce(col("avg_balance"), lit(0)).alias("avg_balance"),
            coalesce(col("max_balance"), lit(0)).alias("max_balance"),
            
            # Transaction behavior (12 months)
            coalesce(col("tx_count_12m"), lit(0)).alias("tx_count_12m"),
            coalesce(col("tx_volume_12m"), lit(0)).alias("tx_volume_12m"),
            coalesce(col("avg_tx_amount_12m"), lit(0)).alias("avg_tx_amount_12m"),
            coalesce(col("max_tx_amount_12m"), lit(0)).alias("max_tx_amount_12m"),
            coalesce(col("unique_merchants_12m"), lit(0)).alias("unique_merchants_12m"),
            coalesce(col("fraud_alerts_12m"), lit(0)).alias("fraud_alerts_12m"),
            col("last_transaction_date"),
            
            # Engagement and activity scores
            when(col("last_transaction_date") >= date_sub(current_date(), 30), "ACTIVE")
            .when(col("last_transaction_date") >= date_sub(current_date(), 90), "MODERATE")
            .when(col("last_transaction_date") >= date_sub(current_date(), 180), "LOW")
            .otherwise("INACTIVE").alias("engagement_level"),
            
            # Relationship value score (composite)
            (coalesce(col("estimated_clv_score"), lit(0)) * 0.4 +
             coalesce(col("total_balance"), lit(0)) / 10000 * 0.3 +
             coalesce(col("tx_volume_12m"), lit(0)) / 100000 * 0.3).alias("relationship_value_score"),
            
            # Data freshness
            current_timestamp().alias("analytics_generated_at")
        )
    ){
  "cells": [
    {
      "cell_type": "code",
