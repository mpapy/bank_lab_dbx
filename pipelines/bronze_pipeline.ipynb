    name="bronze_audit_log",
    comment="Comprehensive audit log for compliance and security monitoring",
    table_properties={
        "quality": "bronze",
        "delta.autoOptimize.optimizeWrite": "true",
        "delta.enableChangeDataFeed": "true"
    }
)
def bronze_audit_log():
    """
    Audit log for all bronze layer activities for compliance
    """
    audit_schema = StructType([
        StructField("event_timestamp", TimestampType(), True),
        StructField("event_type", StringType(), True),
        StructField("table_name", StringType(), True),
        StructField("user_id", StringType(), True),
        StructField("operation_details", StringType(), True),
        StructField("data_classification", StringType(), True),
        StructField("risk_score", IntegerType(), True)
    ])
    
    return spark.createDataFrame([], audit_schema){
