@dlt.table(
    name="bronze_data_quality_metrics",
    comment="Comprehensive data quality metrics for all bronze tables",
    table_properties={
        "quality": "bronze",
        "delta.autoOptimize.optimizeWrite": "true"
    }
)
def bronze_data_quality_metrics():
    """
    Aggregate data quality metrics from all bronze tables for monitoring and alerting
    """
    quality_schema = StructType([
        StructField("table_name", StringType(), True),
        StructField("metric_name", StringType(), True),
        StructField("metric_value", DoubleType(), True),
        StructField("threshold_value", DoubleType(), True),
        StructField("is_within_threshold", BooleanType(), True),
        StructField("severity", StringType(), True),
        StructField("measurement_timestamp", TimestampType(), True),
        StructField("processing_date", StringType(), True)
    ])
    
    # Create sample data quality metrics - in production this would be populated by monitoring jobs
    sample_metrics = [
        ("customers_bronze", "null_percentage", 0.05, 0.10, True, "INFO"),
        ("customers_bronze", "duplicate_percentage", 0.02, 0.05, True, "INFO"),
        ("accounts_bronze", "null_percentage", 0.03, 0.10, True, "INFO"),
        ("card_transactions_bronze", "data_freshness_hours", 2.0, 24.0, True, "INFO")
    ]
    
    rows = [(name, metric, value, threshold, within, severity, current_timestamp(), current_timestamp().cast("date").cast("string")) 
            for name, metric, value, threshold, within, severity in sample_metrics]
    
    return spark.createDataFrame(rows, quality_schema)

