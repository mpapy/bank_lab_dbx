@dlt.table(
    name="fact_transactions_enriched",
    comment="Enriched transaction fact table with fraud detection, behavioral patterns, and advanced analytics",
    table_properties={
        "quality": "silver",
        "delta.autoOptimize.optimizeWrite": "true",
        "delta.autoOptimize.autoCompact": "true",
        "delta.enableChangeDataFeed": "true"
    },
    partition_cols=["transaction_year", "transaction_month", "fraud_risk_level"]
)
def fact_transactions_enriched():
    """
    Create enriched transaction fact table with advanced fraud detection and behavioral analytics
    """
    # Get transactions and enrich with customer data
    card_trans = dlt.readStream(f"{catalog}.{silver_schema}.card_transactions_silver")
    financial_trans = dlt.readStream(f"{catalog}.{silver_schema}.financial_transactions_silver")
    customers = dlt.readStream("dim_customers_enhanced")
    accounts = dlt.readStream("dim_accounts")
    cards = dlt.readStream("dim_cards")
    
    # Union card and financial transactions with common schema
    card_transactions_normalized = (
        card_trans.alias("ct")
        .join(cards.filter(col("__END_AT").isNull()).alias("card"), 
              col("ct.card_id") == col("card.card_id"), "inner")
        .select(
            col("ct.card_transaction_id").alias("transaction_id"),
            lit("CARD").alias("transaction_type"),
            col("card.account_id"),
            col("ct.card_id"),
            col("ct.merchant_id"),
            col("ct.amount"),
            col("ct.datum").alias("transaction_date"),
            col("ct.typ_transakce").alias("transaction_category"),
            hour(col("ct.datum")).alias("transaction_hour"),
            dayofweek(col("ct.datum")).alias("day_of_week"),
            month(col("ct.datum")).alias("transaction_month"),
            year(col("ct.datum")).alias("transaction_year")
        )
    )
    
    financial_transactions_normalized = (
        financial_trans.alias("ft")
        .select(
            col("ft.transaction_id"),
            lit("FINANCIAL").alias("transaction_type"),
            col("ft.account_id"),
            lit(None).cast("string").alias("card_id"),
            lit(None).cast("string").alias("merchant_id"),
            col("ft.amount"),
            col("ft.datum").alias("transaction_date"),
            col("ft.typ_transakce").alias("transaction_category"),
            hour(col("ft.datum")).alias("transaction_hour"),
            dayofweek(col("ft.datum")).alias("day_of_week"),
            month(col("ft.datum")).alias("transaction_month"),
            year(col("ft.datum")).alias("transaction_year")
        )
    )
    
    # Union all transactions
    all_transactions = card_transactions_normalized.unionByName(financial_transactions_normalized)
    
    # Enrich with customer data
    enriched_transactions = (
        all_transactions.alias("trans")
        .join(accounts.filter(col("__END_AT").isNull()).alias("acc"),
              col("trans.account_id") == col("acc.account_id"), "inner")
        .join(customers.alias("cust"),
              col("acc.customer_id") == col("cust.customer_id"), "inner")
    )
    
    # Add advanced analytics and fraud detection
    customer_window = Window.partitionBy("cust.customer_id").orderBy("trans.transaction_date")
    daily_window = Window.partitionBy("cust.customer_id", 
                                     col("trans.transaction_date").cast("date")).orderBy("trans.transaction_date")
    
    return (
        enriched_transactions
        # Transaction patterns and anomalies
        .withColumn("amount_zscore",
                   (col("trans.amount") - avg("trans.amount").over(customer_window)) / 
                   stddev("trans.amount").over(customer_window))
        .withColumn("is_amount_anomaly",
                   when(abs(col("amount_zscore")) > 3, True).otherwise(False))
        
        # Time-based patterns
        .withColumn("is_unusual_hour",
                   when(col("trans.transaction_hour").between(1, 5), True).otherwise(False))
        .withColumn("is_weekend",
                   when(col("trans.day_of_week").isin([1, 7]), True).otherwise(False))
        
        # Velocity checks
        .withColumn("daily_transaction_count",
                   count("*").over(daily_window))
        .withColumn("daily_transaction_amount",
                   sum("trans.amount").over(daily_window))
        .withColumn("is_high_velocity",
                   when((col("daily_transaction_count") > 20) | 
                        (col("daily_transaction_amount") > col("cust.prijem") * 0.5), True).otherwise(False))
        
        # Customer behavior analysis
        .withColumn("amount_to_income_ratio",
                   col("trans.amount") / col("cust.prijem"))
        .withColumn("transaction_risk_category",
                   when(col("amount_to_income_ratio") > 0.1, "HIGH_AMOUNT")
                   .when(col("is_unusual_hour"), "UNUSUAL_TIME")
                   .when(col("is_high_velocity"), "HIGH_VELOCITY")
                   .otherwise("NORMAL"))
        
        # Comprehensive fraud risk scoring
        .withColumn("fraud_risk_score",
                   (when(col("is_amount_anomaly"), 30).otherwise(0) +
                    when(col("is_unusual_hour"), 20).otherwise(0) +
                    when(col("is_high_velocity"), 25).otherwise(0) +
                    when(col("amount_to_income_ratio") > 0.2, 15).otherwise(0) +
                    when(col("cust.risk_category") == "VERY_HIGH", 10).otherwise(0)))
        
        .withColumn("fraud_risk_level",
                   when(col("fraud_risk_score") >= 70, "CRITICAL")
                   .when(col("fraud_risk_score") >= 40, "HIGH")
                   .when(col("fraud_risk_score") >= 20, "MEDIUM")
                   .otherwise("LOW"))
        
        # Business intelligence features
        .withColumn("customer_segment_at_transaction", col("cust.customer_segment"))
        .withColumn("customer_clv_at_transaction", col("cust.estimated_clv_score"))
        
        # Select final columns
        .select(
            col("trans.transaction_id"),
            col("trans.transaction_type"),
            col("trans.account_id"),
            col("cust.customer_id"),
            col("trans.card_id"),
            col("trans.merchant_id"),
            col("trans.amount"),
            col("trans.transaction_date"),
            col("trans.transaction_category"),
            col("trans.transaction_hour"),
            col("trans.day_of_week"),
            col("trans.transaction_month"),
            col("trans.transaction_year"),
            # Analytics columns
            "amount_zscore", "is_amount_anomaly", "is_unusual_hour", "is_weekend",
            "daily_transaction_count", "daily_transaction_amount", "is_high_velocity",
            "amount_to_income_ratio", "transaction_risk_category",
            "fraud_risk_score", "fraud_risk_level",
            "customer_segment_at_transaction", "customer_clv_at_transaction",
            # Metadata
            current_timestamp().alias("processed_at")
        )
    )# ===============================================================================
#                    ENHANCED CUSTOMER DIMENSION WITH ADVANCED ANALYTICS
# ===============================================================================

@dlt.table(
    name="dim_customers_enhanced",
    comment="Enhanced customer dimension with advanced segmentation, risk scoring, and behavioral analytics",
    table_properties={
        "quality": "silver",
        "delta.autoOptimize.optimizeWrite": "true",
        "delta.autoOptimize.autoCompact": "true",
        "delta.enableChangeDataFeed": "true"
    },
    partition_cols=["risk_category", "customer_segment_hash"]
)
def dim_customers_enhanced():
    """
    Create enhanced customer dimension with sophisticated business logic
    """
    df_customer = dlt.readStream('customers_clean_good_records')
    
    # Apply all advanced business functions
    enhanced_customers = (df_customer
        .transform(calculate_customer_risk_score)
        .transform(add_customer_segmentation)  
        .transform(calculate_financial_health_indicators)
    )
    
    # Add additional advanced features
    window_spec = Window.partitionBy("mesto").orderBy("prijem")
    
    return (enhanced_customers
        # Geographic and demographic analytics
        .withColumn("income_percentile_in_city", 
                   percent_rank().over(window_spec))
        .withColumn("is_high_income_in_city",
                   when(col("income_percentile_in_city") > 0.8, True).otherwise(False))
        
        # Customer lifetime value estimation
        .withColumn("estimated_clv_score",
                   (col("prijem") * 0.02 * col("days_from_open_first_acc") / 365 * 
                    when(col("financial_stability_score") > 4, 1.5)
                    .when(col("financial_stability_score") > 3, 1.2)
                    .otherwise(1.0)))
        
        # Behavioral indicators
        .withColumn("is_family_oriented",
                   when(col("pocet_clenu_domacnost") > 2, True).otherwise(False))
        .withColumn("housing_status",
                   when(col("typ_bydleni") == "vlastni", "Owner")
                   .when(col("typ_bydleni") == "najem", "Renter")
                   .otherwise("Other"))
        
        # Advanced segmentation hash for partitioning
        .withColumn("customer_segment_hash",
                   abs(hash(col("customer_segment")) % 10))
        
        # Data governance and lineage
        .withColumn("enhanced_at", current_timestamp())
        .withColumn("data_version", lit("2.0"))
        .withColumn("contains_pii", lit(True))
        .withColumn("gdpr_compliant", lit(True))
        
        # Select final columns for dimension
        .select(
            "customer_id", "jmeno", "prijmeni", "email", "tel_cislo",
            "client_age", "pohlavi", "pracovni_stav", "typ_bydleni",
            "mesto", "zip_code", "zeme", "prijem", "pocet_clenu_domacnost",
            "pocet_nemovitosti", "days_from_open_first_acc",
            # Risk and scoring
            "overall_risk_score", "risk_category", "financial_stability_score",
            # Segmentation
            "life_stage", "wealth_segment", "banking_tenure_segment", "customer_segment",
            # Financial indicators
            "savings_rate", "savings_category", "income_per_household_member",
            # Advanced analytics
            "income_percentile_in_city", "is_high_income_in_city", "estimated_clv_score",
            "is_family_oriented", "housing_status",
            # Metadata
            "customer_segment_hash", "enhanced_at", "data_version", "snapshot_date"
        )
    )# ===============================================================================
#                    ENHANCED SILVER LAYER BUSINESS FUNCTIONS
# ===============================================================================

# Advanced Business Rules Engine
def calculate_customer_risk_score(df):
    """
    Calculate comprehensive customer risk score based on multiple factors
    """
    return (df
        .withColumn("income_risk_score", 
                   when(col("prijem") > 100000, 1)
                   .when(col("prijem") > 50000, 2)
                   .when(col("prijem") > 25000, 3)
                   .otherwise(4))
        .withColumn("age_risk_score",
                   when(col("client_age") < 25, 3)
                   .when(col("client_age") > 65, 2)
                   .otherwise(1))
        .withColumn("employment_risk_score",
                   when(col("pracovni_stav") == "nezamestnan", 4)
                   .when(col("pracovni_stav") == "student", 3)
                   .when(col("pracovni_stav") == "duchod", 2)
                   .otherwise(1))
        .withColumn("property_risk_score",
                   when(col("pocet_nemovitosti") > 3, 1)
                   .when(col("pocet_nemovitosti") > 1, 2)
                   .otherwise(3))
        .withColumn("overall_risk_score",
                   (col("income_risk_score") * 0.4 + 
                    col("age_risk_score") * 0.2 + 
                    col("employment_risk_score") * 0.3 + 
                    col("property_risk_score") * 0.1))
        .withColumn("risk_category",
                   when(col("overall_risk_score") <= 1.5, "LOW")
                   .when(col("overall_risk_score") <= 2.5, "MEDIUM")
                   .when(col("overall_risk_score") <= 3.5, "HIGH")
                   .otherwise("VERY_HIGH"))
    )

def add_customer_segmentation(df):
    """
    Advanced customer segmentation using multiple dimensions
    """
    return (df
        .withColumn("life_stage",
                   when(col("client_age") < 25, "Young_Adult")
                   .when(col("client_age") < 35, "Early_Career")
                   .when(col("client_age") < 45, "Mid_Career")
                   .when(col("client_age") < 55, "Peak_Career")
                   .when(col("client_age") < 65, "Pre_Retirement")
                   .otherwise("Retirement"))
        .withColumn("wealth_segment",
                   when((col("prijem") > 80000) & (col("pocet_nemovitosti") > 2), "Affluent")
                   .when(col("prijem") > 60000, "Upper_Middle")
                   .when(col("prijem") > 40000, "Middle")
                   .when(col("prijem") > 25000, "Lower_Middle")
                   .otherwise("Mass_Market"))
        .withColumn("banking_tenure_segment",
                   when(col("days_from_open_first_acc") > 3650, "Loyal_10_Plus")
                   .when(col("days_from_open_first_acc") > 1825, "Established_5_Plus")
                   .when(col("days_from_open_first_acc") > 730, "Growing_2_Plus")
                   .when(col("days_from_open_first_acc") > 365, "Developing_1_Plus")
                   .otherwise("New_Customer"))
        .withColumn("customer_segment",
                   concat_ws("_", col("life_stage"), col("wealth_segment"), col("banking_tenure_segment")))
    )

def calculate_financial_health_indicators(df):
    """
    Calculate comprehensive financial health indicators
    """
    return (df
        .withColumn("savings_rate",
                   when(col("prijem") > 0, col("sum_prm_uspor_12m") / col("prijem")).otherwise(0))
        .withColumn("savings_category",
                   when(col("savings_rate") > 0.3, "High_Saver")
                   .when(col("savings_rate") > 0.15, "Medium_Saver")
                   .when(col("savings_rate") > 0.05, "Low_Saver")
                   .otherwise("Non_Saver"))
        .withColumn("income_per_household_member",
                   when(col("pocet_clenu_domacnost") > 0, 
                        col("prijem") / col("pocet_clenu_domacnost")).otherwise(col("prijem")))
        .withColumn("financial_stability_score",
                   (when(col("savings_rate") > 0.2, 5)
                    .when(col("savings_rate") > 0.1, 4)
                    .when(col("savings_rate") > 0.05, 3)
                    .when(col("savings_rate") > 0, 2)
                    .otherwise(1) * 0.4) +
                   (when(col("pocet_nemovitosti") > 2, 5)
                    .when(col("pocet_nemovitosti") > 1, 4)
                    .when(col("pocet_nemovitosti") == 1, 3)
                    .otherwise(1) * 0.3) +
                   (when(col("income_per_household_member") > 50000, 5)
                    .when(col("income_per_household_member") > 30000, 4)
                    .when(col("income_per_household_member") > 20000, 3)
                    .when(col("income_per_household_member") > 10000, 2)
                    .otherwise(1) * 0.3))
    ){
